// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  leads     Lead[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id           Int       @id @default(autoincrement())
  name         String
  email        String?
  phone        String?
  company      String?
  website      String?
  jobRole      String?
  industry     String?
  companySize  String?
  techStack    String?
  funding      String?
  location     String?
  linkedinUrl  String?
  linkedinFounderUrl String?
  source       String
  budget       Float?
  status       String    @default("New")
  aiScore      Int       @default(0)
  aiCategory   String?   // Hot | Warm | Cold
  aiReason     String?   @db.Text
  aiInsight    String?   @db.Text
  aiEmailDraft String?   @db.Text
  notes        String?   @db.Text
  isConverted  Boolean   @default(false)
  convertedAt  DateTime?

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

